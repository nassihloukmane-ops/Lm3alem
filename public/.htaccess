# Contenu du dossier "out/" → uploader dans public_html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # HTTPS obligatoire
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Version canonique : non-www (https://lm3alem.com)
  RewriteCond %{HTTP_HOST} ^www\.lm3alem\.com$ [NC]
  RewriteRule ^ https://lm3alem.com%{REQUEST_URI} [L,R=301]

  # Assets Next (dossier "next/" — Hostinger bloque souvent "_next")
  RewriteRule ^next/ - [L]
  RewriteRule ^_next/(.*)$ /next/$1 [L]
  RewriteRule \.(js|css|png|jpg|jpeg|webp|svg|ico|gif|woff2|webmanifest|xml|txt|map)$ - [L]

  # SPA fallback uniquement si le fichier n'existe pas
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# Types MIME
<IfModule mod_mime.c>
  AddType text/css .css
  AddType application/javascript .js
  AddType application/manifest+json .webmanifest
  AddType application/xml .xml
  AddType font/woff2 .woff2
  AddType image/svg+xml .svg
</IfModule>

# Compression Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml image/svg+xml application/manifest+json
  AddOutputFilterByType DEFLATE font/woff2 application/font-woff2
</IfModule>

# Cache navigateur — assets Next hashés = longue durée
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 hour"

  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"

  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
  Header always unset X-Robots-Tag

  # HTML : revalidation rapide
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # JS/CSS Next (_next/static) : immuables
  <FilesMatch "\.(js|css|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images / favicons
  <FilesMatch "\.(png|jpg|jpeg|webp|svg|ico|gif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Sécurité légère (n’impacte pas le design)
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
