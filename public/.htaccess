# Contenu du dossier "out/" → uploader dans public_html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # HTTPS obligatoire
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Version canonique : non-www (https://lm3alem.com)
  RewriteCond %{HTTP_HOST} ^www\.lm3alem\.com$ [NC]
  RewriteRule ^ https://lm3alem.com%{REQUEST_URI} [L,R=301]

  # Servir les fichiers existants directement (robots.txt, sitemap.xml, assets)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Rediriger vers index.html pour les routes SPA
  RewriteRule ^ index.html [L]
</IfModule>

# Types MIME
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType application/xml .xml
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/xml text/plain
</IfModule>

# Sécurité : pas de blocage d'indexation
<IfModule mod_headers.c>
  Header always unset X-Robots-Tag
</IfModule>
